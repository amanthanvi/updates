# Auto detect text files and perform LF normalization
* text=auto

# Enforce LF for checkout-critical scripts, launchers, workflows, and release inputs.
updates text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf
*.cmd text eol=lf
*.bat text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
Makefile text eol=lf
.github/workflows/*.yml text eol=lf
.github/workflows/*.yaml text eol=lf
