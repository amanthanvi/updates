#!/bin/bash

set -o pipefail

###############################################################################
# SECTION: globals — version, state variables, module registry
###############################################################################

UPDATES_VERSION="2.0.0"

SCRIPT_NAME="$(basename "$0")"

DRY_RUN=0
STRICT=0
NO_EMOJI=0
NO_COLOR_OUTPUT=0
NON_INTERACTIVE=0
PYTHON_BREAK_SYSTEM_PACKAGES=0
LOG_FILE=""
PARALLEL=4
SELF_UPDATE=1
SELF_UPDATE_FORCE_REFRESH=0
NO_CONFIG=0
JSON=0
GO_BINARIES=""
REPOS_DIR=""

LOG_LEVEL="info"
LOG_LEVEL_NUM=2
HUMAN_FD=1

BREW_GREEDY=1
BREW_CLEANUP=1
BREW_CASKS=1
BREW_CASKS_EXPLICIT=0

MAS_UPGRADE=0
MACOS_UPDATES=0

only_modules=()
skip_modules=()
config_skip_modules=()
successes=()
skipped=()
failures=()

CURRENT_MODULE="main"

COLOR_STDOUT=0
COLOR_STDERR=0
C_RESET=""
C_BOLD=""
C_DIM=""
C_RED=""
C_GREEN=""
C_YELLOW=""
C_BLUE=""

MODULE_REGISTRY='brew|module_brew|macos,linux|0|Update Homebrew formulae (+ optional casks)
shell|module_shell|macos,linux|0|Update Oh My Zsh and custom git plugins/themes
repos|module_repos|macos,linux|0|Update aman dev repos under ~/GitRepos
linux|module_linux|linux|0|Upgrade Linux system packages
winget|module_winget|windows|0|Upgrade Windows packages via winget
node|module_node|macos,linux|0|Upgrade global npm packages via npm-check-updates
bun|module_bun|macos,linux|0|Update Bun globals (and Bun itself when standalone-installed)
python|module_python|macos,linux|0|Upgrade global Python packages via pip
uv|module_uv|macos,linux|0|Update uv and uv-managed tools
mas|module_mas|macos|1|Upgrade Mac App Store apps via mas (opt-in)
pipx|module_pipx|macos,linux|0|Upgrade pipx-managed apps via pipx
rustup|module_rustup|macos,linux|0|Update Rust toolchains via rustup
claude|module_claude|macos,linux|0|Update Claude Code CLI
pi|module_pi|macos,linux|0|Update pi AI CLI extensions via pi update
mise|module_mise|macos,linux|0|Update mise and upgrade installed tools
go|module_go|macos,linux|0|Update Go binaries from GO_BINARIES config
macos|module_macos|macos|1|List available macOS software updates (opt-in)'

MODULE_LOOKUP_HANDLER=""
MODULE_LOOKUP_PLATFORM=""
MODULE_LOOKUP_OPT_IN=""
MODULE_LOOKUP_DESCRIPTION=""

PLATFORM_CACHE_READY=0
OS_NAME=""
IS_MACOS=0
IS_LINUX=0
IS_WSL=0

JSON_TS_CACHE_SECONDS=""
JSON_TS_CACHE_VALUE=""

SELF_UPDATE_CACHE_TTL=86400
SELF_UPDATE_CACHE_CHECKED_AT=""
SELF_UPDATE_CACHE_LATEST_TAG=""

BREW_FORMULA_DEFAULT_HINT_EMITTED=0

SELF_UPDATE_REPO="amanthanvi/updates"
SELF_UPDATE_RELEASE_CHANNEL="github-release"
SELF_UPDATE_RELEASE_MANIFEST_NAME="updates-release.json"
SELF_UPDATE_UNIX_ASSET_NAME="updates"
SELF_UPDATE_WINDOWS_ASSET_NAME="updates-windows.zip"
SELF_UPDATE_CHECKSUM_ASSET_NAME="SHA256SUMS"

PYTHON_LAUNCHER_READY=0
PYTHON_CMD=""
PYTHON_CMD_ARG=""
PYTHON_CMD_LABEL=""

NCU_RESOLVED=0
NCU_MODE=""
NCU_CMD=""

###############################################################################
# SECTION: output — print, log, warn, err, emoji, JSON emission
###############################################################################

print() {
	printf '%s\n' "$*" >&"$HUMAN_FD"
}

stdout_print() {
	printf '%s\n' "$*"
}

module_lookup() {
	local needle="$1"
	local name handler platform opt_in description

	while IFS='|' read -r -u3 name handler platform opt_in description; do
		[ -n "$name" ] || continue
		if [ "$name" != "$needle" ]; then
			continue
		fi

		MODULE_LOOKUP_HANDLER="$handler"
		MODULE_LOOKUP_PLATFORM="$platform"
		MODULE_LOOKUP_OPT_IN="$opt_in"
		MODULE_LOOKUP_DESCRIPTION="$description"
		return 0
	done 3<<<"$MODULE_REGISTRY"

	return 1
}

set_log_level() {
	case "$1" in
	error)
		LOG_LEVEL="error"
		LOG_LEVEL_NUM=0
		;;
	warn)
		LOG_LEVEL="warn"
		LOG_LEVEL_NUM=1
		;;
	info)
		LOG_LEVEL="info"
		LOG_LEVEL_NUM=2
		;;
	debug)
		LOG_LEVEL="debug"
		LOG_LEVEL_NUM=3
		;;
	*)
		die "--log-level must be one of: error, warn, info, debug"
		;;
	esac
}

json_enabled() {
	[ "$JSON" -eq 1 ]
}

json_timestamp() {
	local current_seconds="$SECONDS"
	if [ "$JSON_TS_CACHE_SECONDS" = "$current_seconds" ] && [ -n "$JSON_TS_CACHE_VALUE" ]; then
		printf '%s' "$JSON_TS_CACHE_VALUE"
		return 0
	fi

	JSON_TS_CACHE_VALUE="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
	JSON_TS_CACHE_SECONDS="$current_seconds"
	printf '%s' "$JSON_TS_CACHE_VALUE"
}

json_escape() {
	local s="$1"
	s="${s//\\/\\\\}"
	s="${s//\"/\\\"}"
	s="${s//$'\n'/\\n}"
	s="${s//$'\r'/\\r}"
	s="${s//$'\t'/\\t}"
	printf '%s' "$s"
}

json_emit_message_event() {
	local event="$1"
	local module="$2"
	local message="$3"

	if ! json_enabled; then
		return 0
	fi

	local ts
	ts="$(json_timestamp)"

	printf '{"event":"%s","module":"%s","message":"%s","timestamp":"%s"}\n' \
		"$event" \
		"$(json_escape "$module")" \
		"$(json_escape "$message")" \
		"$ts"
}

json_emit_module_start() {
	local module="$1"

	if ! json_enabled; then
		return 0
	fi

	local ts
	ts="$(json_timestamp)"

	printf '{"event":"module_start","module":"%s","timestamp":"%s"}\n' \
		"$(json_escape "$module")" \
		"$ts"
}

json_emit_module_end() {
	local module="$1"
	local status="$2"
	local seconds="$3"

	if ! json_enabled; then
		return 0
	fi

	local ts
	ts="$(json_timestamp)"

	printf '{"event":"module_end","module":"%s","status":"%s","seconds":%s,"timestamp":"%s"}\n' \
		"$(json_escape "$module")" \
		"$(json_escape "$status")" \
		"$seconds" \
		"$ts"
}

json_array() {
	local first=1
	printf '['
	local item
	for item in "$@"; do
		if [ "$first" -eq 0 ]; then
			printf ','
		fi
		first=0
		printf '"%s"' "$(json_escape "$item")"
	done
	printf ']'
}

json_emit_summary() {
	local ok="$1"
	local skip="$2"
	local fail="$3"
	local total_seconds="$4"
	shift 4
	local -a failures=("$@")

	if ! json_enabled; then
		return 0
	fi

	local ts
	ts="$(json_timestamp)"

	printf '{"event":"summary","ok":%s,"skip":%s,"fail":%s,"total_seconds":%s,"failures":%s,"timestamp":"%s"}\n' \
		"$ok" \
		"$skip" \
		"$fail" \
		"$total_seconds" \
		"$(json_array "${failures[@]}")" \
		"$ts"
}

progress() {
	if [ "$LOG_LEVEL_NUM" -ge 1 ]; then
		print "$*"
	fi
}

log() {
	json_emit_message_event log "$CURRENT_MODULE" "$*"
	if [ "$LOG_LEVEL_NUM" -ge 2 ]; then
		print "$*"
	fi
}

debug() {
	json_emit_message_event log "$CURRENT_MODULE" "$*"
	if [ "$LOG_LEVEL_NUM" -ge 3 ]; then
		print "$*"
	fi
}

###############################################################################
# SECTION: colors — ANSI init, boundary lines, summary formatting
###############################################################################

init_colors() {
	COLOR_STDOUT=0
	COLOR_STDERR=0
	C_RESET=""
	C_BOLD=""
	C_DIM=""
	C_RED=""
	C_GREEN=""
	C_YELLOW=""
	C_BLUE=""

	if [ "$NO_COLOR_OUTPUT" -eq 1 ] || [ -n "${NO_COLOR:-}" ] || [ "${TERM:-}" = "dumb" ]; then
		return 0
	fi

	if [ -t 1 ]; then
		COLOR_STDOUT=1
	fi
	if [ -t 2 ]; then
		COLOR_STDERR=1
	fi

	if [ "$COLOR_STDOUT" -eq 0 ] && [ "$COLOR_STDERR" -eq 0 ]; then
		return 0
	fi

	C_RESET=$'\033[0m'
	C_BOLD=$'\033[1m'
	C_DIM=$'\033[2m'
	C_RED=$'\033[31m'
	C_GREEN=$'\033[32m'
	C_YELLOW=$'\033[33m'
	C_BLUE=$'\033[34m'
}

warn() {
	json_emit_message_event warn "$CURRENT_MODULE" "$*"
	if [ "$LOG_LEVEL_NUM" -lt 1 ]; then
		return 0
	fi
	if [ "$COLOR_STDERR" -eq 1 ]; then
		printf '%s\n' "${C_YELLOW}WARN:${C_RESET} $*" >&2
	else
		printf '%s\n' "WARN: $*" >&2
	fi
}

err() {
	json_emit_message_event error "$CURRENT_MODULE" "$*"
	if [ "$COLOR_STDERR" -eq 1 ]; then
		printf '%s\n' "${C_RED}ERROR:${C_RESET} $*" >&2
	else
		printf '%s\n' "ERROR: $*" >&2
	fi
}

die() {
	err "$*"
	exit 2
}

emoji() {
	if [ "$NO_EMOJI" -eq 1 ]; then
		return 0
	fi
	printf '%s' "$1"
}

format_boundary_start() {
	local module="$1"
	if [ "$COLOR_STDOUT" -eq 1 ]; then
		printf '%s %s START' "${C_BLUE}${C_BOLD}==>${C_RESET}" "${C_BOLD}${module}${C_RESET}"
		return 0
	fi
	printf '==> %s START' "$module"
}

format_boundary_end() {
	local module="$1"
	local status="$2"
	local dur="$3"

	if [ "$COLOR_STDOUT" -ne 1 ]; then
		printf '==> %s END (%s) (%ss)' "$module" "$status" "$dur"
		return 0
	fi

	local status_color=""
	case "$status" in
	OK) status_color="$C_GREEN" ;;
	SKIP) status_color="$C_YELLOW" ;;
	FAIL) status_color="$C_RED" ;;
	esac

	printf '%s %s END (%s%s%s) %s(%ss)%s' \
		"${C_BLUE}${C_BOLD}==>${C_RESET}" \
		"${C_BOLD}${module}${C_RESET}" \
		"$status_color" "$status" "$C_RESET" \
		"$C_DIM" "$dur" "$C_RESET"
}

format_summary() {
	local ok="$1"
	local skip="$2"
	local fail="$3"
	local total="$4"
	local failures_csv="${5:-}"

	if [ "$COLOR_STDOUT" -ne 1 ]; then
		local line="==> SUMMARY ok=${ok} skip=${skip} fail=${fail} total=${total}s"
		if [ -n "$failures_csv" ]; then
			line="${line} failures=${failures_csv}"
		fi
		printf '%s' "$line"
		return 0
	fi

	local line="${C_BLUE}${C_BOLD}==>${C_RESET} ${C_BOLD}SUMMARY${C_RESET}"
	line="${line} ${C_GREEN}ok=${ok}${C_RESET}"
	line="${line} ${C_YELLOW}skip=${skip}${C_RESET}"
	line="${line} ${C_RED}fail=${fail}${C_RESET}"
	line="${line} ${C_DIM}total=${total}s${C_RESET}"
	if [ -n "$failures_csv" ]; then
		line="${line} ${C_RED}failures=${failures_csv}${C_RESET}"
	fi
	printf '%s' "$line"
}

###############################################################################
# SECTION: platform — detection, defaults, brew mode
###############################################################################

cmd_exists() {
	command -v "$1" >/dev/null 2>&1
}

init_platform_cache() {
	if [ "$PLATFORM_CACHE_READY" -eq 1 ]; then
		return 0
	fi

	OS_NAME="$(uname -s 2>/dev/null || true)"
	case "$OS_NAME" in
	Darwin)
		IS_MACOS=1
		IS_LINUX=0
		;;
	Linux)
		IS_MACOS=0
		IS_LINUX=1
		;;
	*)
		IS_MACOS=0
		IS_LINUX=0
		;;
	esac

	if [ -n "${WSL_DISTRO_NAME:-}" ]; then
		IS_WSL=1
	elif [ "$IS_LINUX" -eq 1 ] && [ -f /proc/sys/kernel/osrelease ] && grep -qi microsoft /proc/sys/kernel/osrelease; then
		IS_WSL=1
	elif [ "$IS_LINUX" -eq 1 ] && [ -f /proc/version ] && grep -qi microsoft /proc/version; then
		IS_WSL=1
	else
		IS_WSL=0
	fi

	PLATFORM_CACHE_READY=1
}

is_macos() {
	init_platform_cache
	[ "$IS_MACOS" -eq 1 ]
}

is_linux() {
	init_platform_cache
	[ "$IS_LINUX" -eq 1 ]
}

is_wsl() {
	init_platform_cache
	[ "$IS_WSL" -eq 1 ]
}

updates_home_dir() {
	if [ -n "${HOME:-}" ]; then
		stdout_print "${HOME}"
		return 0
	fi
	if [ -n "${USERPROFILE:-}" ]; then
		stdout_print "${USERPROFILE}"
		return 0
	fi
	return 1
}

updates_config_path() {
	local home_dir=""
	if ! home_dir="$(updates_home_dir)"; then
		return 1
	fi
	stdout_print "${home_dir}/.updatesrc"
}

current_platform_name() {
	if is_macos; then
		stdout_print "macos"
		return 0
	fi
	if is_linux; then
		stdout_print "linux"
		return 0
	fi
	stdout_print "unknown"
}

platform_list_contains() {
	local list="$1"
	local needle="$2"
	case ",${list}," in
	*",${needle},"*) return 0 ;;
	esac
	return 1
}

apply_platform_defaults() {
	# macOS 26+ introduces App Management prompts for app bundle updates (/Applications).
	# Default to formula upgrades only unless explicitly opted in.
	if is_macos && [ "$BREW_CASKS_EXPLICIT" -eq 0 ]; then
		BREW_CASKS=0
	fi
}

set_brew_mode() {
	local mode="$1"
	local ctx="${2:-cli}"

	case "$mode" in
	formula)
		BREW_CASKS=0
		BREW_GREEDY=0
		BREW_CASKS_EXPLICIT=1
		;;
	casks)
		BREW_CASKS=1
		BREW_GREEDY=0
		BREW_CASKS_EXPLICIT=1
		;;
	greedy)
		BREW_CASKS=1
		BREW_GREEDY=1
		BREW_CASKS_EXPLICIT=1
		;;
	*)
		if [ "$ctx" = "config" ]; then
			warn "config: BREW_MODE must be formula, casks, or greedy (got: $mode)"
			return 1
		fi
		die "--brew-mode must be one of: formula, casks, greedy"
		;;
	esac
}

###############################################################################
# SECTION: registry — module lookup, validation, support checks
###############################################################################

module_known() {
	module_lookup "$1"
}

module_handler() {
	if ! module_lookup "$1"; then
		return 1
	fi
	stdout_print "$MODULE_LOOKUP_HANDLER"
}

module_enabled_by_default() {
	if ! module_lookup "$1"; then
		return 1
	fi

	if [ "$MODULE_LOOKUP_OPT_IN" != "1" ]; then
		return 0
	fi

	case "$1" in
	mas) [ "$MAS_UPGRADE" -eq 1 ] ;;
	macos) [ "$MACOS_UPDATES" -eq 1 ] ;;
	*) return 1 ;;
	esac
}

module_supported() {
	if ! module_lookup "$1"; then
		return 1
	fi

	local platform=""
	platform="$(current_platform_name)"
	if platform_list_contains "$MODULE_LOOKUP_PLATFORM" "$platform"; then
		return 0
	fi

	if [ "${UPDATES_ALLOW_NON_DARWIN:-0}" = "1" ] && [ "$platform" = "unknown" ]; then
		if platform_list_contains "$MODULE_LOOKUP_PLATFORM" macos && platform_list_contains "$MODULE_LOOKUP_PLATFORM" linux; then
			return 0
		fi
	fi

	return 1
}

require_supported_platform() {
	if is_macos || is_linux; then
		return 0
	fi
	if [ "${UPDATES_ALLOW_NON_DARWIN:-0}" = "1" ]; then
		warn "Unsupported OS detected; continuing because UPDATES_ALLOW_NON_DARWIN=1 is set."
		return 0
	fi
	die "This script targets macOS and Linux. Set UPDATES_ALLOW_NON_DARWIN=1 to bypass."
}

validate_only_modules_supported() {
	if [ "${#only_modules[@]}" -eq 0 ]; then
		return 0
	fi

	local m
	for m in "${only_modules[@]}"; do
		if module_supported "$m"; then
			continue
		fi
		die "$m: module is not supported on this platform"
	done
}

###############################################################################
# SECTION: utilities — run wrapper, semver comparison
###############################################################################

run() {
	debug "+ $*"
	if [ "$DRY_RUN" -eq 1 ]; then
		return 0
	fi
	if [ "$JSON" -eq 1 ]; then
		"$@" 1>&2
	else
		"$@"
	fi
}

semver_is_valid() {
	[[ "${1:-}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]
}

semver_lt() {
	# Returns 0 if $1 < $2, else 1.
	local a="$1"
	local b="$2"
	semver_is_valid "$a" || return 1
	semver_is_valid "$b" || return 1

	local a1 a2 a3 b1 b2 b3
	IFS=. read -r a1 a2 a3 <<<"$a"
	IFS=. read -r b1 b2 b3 <<<"$b"

	if [ "$a1" -ne "$b1" ]; then
		[ "$a1" -lt "$b1" ]
		return $?
	fi
	if [ "$a2" -ne "$b2" ]; then
		[ "$a2" -lt "$b2" ]
		return $?
	fi
	[ "$a3" -lt "$b3" ]
	return $?
}

python_launcher_reset() {
	PYTHON_LAUNCHER_READY=0
	PYTHON_CMD=""
	PYTHON_CMD_ARG=""
	PYTHON_CMD_LABEL=""
}

python_launcher_resolve() {
	if [ "$PYTHON_LAUNCHER_READY" -eq 1 ]; then
		[ -n "$PYTHON_CMD" ]
		return $?
	fi

	python_launcher_reset

	if cmd_exists py && py -3 -c 'import sys' >/dev/null 2>&1; then
		PYTHON_CMD="py"
		PYTHON_CMD_ARG="-3"
		PYTHON_CMD_LABEL="py -3"
	elif cmd_exists python; then
		PYTHON_CMD="python"
		PYTHON_CMD_LABEL="python"
	elif cmd_exists python3; then
		PYTHON_CMD="python3"
		PYTHON_CMD_LABEL="python3"
	fi

	PYTHON_LAUNCHER_READY=1
	[ -n "$PYTHON_CMD" ]
}

python_run_cmd() {
	if ! python_launcher_resolve; then
		return 1
	fi

	if [ -n "$PYTHON_CMD_ARG" ]; then
		"$PYTHON_CMD" "$PYTHON_CMD_ARG" "$@"
		return $?
	fi

	"$PYTHON_CMD" "$@"
}

resolve_ncu_runner() {
	if [ "$NCU_RESOLVED" -eq 1 ]; then
		[ -n "$NCU_MODE" ]
		return $?
	fi

	NCU_RESOLVED=1
	NCU_MODE=""
	NCU_CMD=""

	if cmd_exists ncu; then
		NCU_MODE="cmd"
		NCU_CMD="ncu"
		return 0
	fi
	if cmd_exists ncu.cmd; then
		NCU_MODE="cmd"
		NCU_CMD="ncu.cmd"
		return 0
	fi
	if cmd_exists npx; then
		NCU_MODE="npx"
		NCU_CMD="npx"
		return 0
	fi
	return 1
}

ncu_command_label() {
	if ! resolve_ncu_runner; then
		return 1
	fi

	case "$NCU_MODE" in
	cmd) stdout_print "${NCU_CMD} -g --jsonUpgraded" ;;
	npx) stdout_print "npx --yes npm-check-updates -g --jsonUpgraded" ;;
	*) return 1 ;;
	esac
}

ncu_run_json_upgraded() {
	if ! resolve_ncu_runner; then
		return 1
	fi

	case "$NCU_MODE" in
	cmd) "$NCU_CMD" -g --jsonUpgraded ;;
	npx) npx --yes npm-check-updates -g --jsonUpgraded ;;
	*) return 1 ;;
	esac
}

bun_is_standalone_install() {
	if ! cmd_exists bun; then
		return 1
	fi

	local bun_path=""
	bun_path="$(command -v bun 2>/dev/null || true)"
	[ -n "$bun_path" ] || return 1

	local home_dir=""
	if ! home_dir="$(updates_home_dir)"; then
		return 1
	fi

	case "$bun_path" in
	"${home_dir}/.bun/bin/bun" | "${home_dir}/.bun/bin/bun.exe")
		return 0
		;;
	esac

	return 1
}

###############################################################################
# SECTION: self-update — GitHub release check, download, verify, re-exec
###############################################################################

self_update_enabled() {
	if [ "$SELF_UPDATE" -ne 1 ]; then
		return 1
	fi
	if [ "${UPDATES_SELF_UPDATE:-1}" = "0" ]; then
		return 1
	fi
	if [ -n "${CI:-}" ]; then
		return 1
	fi
	if [ "${UPDATES_SELF_UPDATED:-0}" = "1" ]; then
		return 1
	fi
	# Do not self-update in dry-run mode.
	if [ "$DRY_RUN" -eq 1 ]; then
		return 1
	fi
	return 0
}

self_update_resolve_self_path() {
	local self="$0"
	if [ -f "$self" ]; then
		stdout_print "$self"
		return 0
	fi

	self="$(command -v "$SCRIPT_NAME" 2>/dev/null || true)"
	[ -n "$self" ] || return 1
	[ -f "$self" ] || return 1
	stdout_print "$self"
	return 0
}

self_update_is_git_checkout() {
	local self_path="$1"
	if ! cmd_exists git; then
		return 1
	fi

	local dir=""
	dir="$(cd "$(dirname "$self_path")" && pwd)"
	git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

self_update_latest_release_json_github() {
	local repo="$1"
	local api="https://api.github.com/repos/${repo}/releases/latest"

	curl -fsSL --connect-timeout 2 --max-time 5 "$api" 2>/dev/null || return 1
}

self_update_parse_release_metadata() {
	if python_launcher_resolve; then
		python_run_cmd -c 'import json, sys
obj = json.load(sys.stdin)
print("tag_name\t%s" % obj.get("tag_name", ""))
print("draft\t%s" % ("1" if obj.get("draft") else "0"))
print("prerelease\t%s" % ("1" if obj.get("prerelease") else "0"))
print("immutable\t%s" % ("1" if obj.get("immutable") else "0"))
for asset in obj.get("assets", []) or []:
    print("asset\t%s\t%s\t%s" % (
        asset.get("name", ""),
        asset.get("digest", ""),
        asset.get("browser_download_url", ""),
    ))' 2>/dev/null
		return $?
	fi

	if cmd_exists node; then
		# shellcheck disable=SC2016
		node -e 'let data="";process.stdin.on("data",c=>data+=c);process.stdin.on("end",()=>{const obj=JSON.parse(data||"{}");const bool=v=>v?"1":"0";process.stdout.write(`tag_name\t${obj.tag_name||""}\n`);process.stdout.write(`draft\t${bool(obj.draft)}\n`);process.stdout.write(`prerelease\t${bool(obj.prerelease)}\n`);process.stdout.write(`immutable\t${bool(obj.immutable)}\n`);for(const asset of (obj.assets||[])){process.stdout.write(`asset\t${asset.name||""}\t${asset.digest||""}\t${asset.browser_download_url||""}\n`);}});' 2>/dev/null
		return $?
	fi

	return 1
}

self_update_parse_release_manifest() {
	if python_launcher_resolve; then
		python_run_cmd -c 'import json, sys
obj = json.load(sys.stdin)
for key in ("version", "source_repo", "channel", "bootstrap_min", "windows_asset", "unix_asset", "checksum_asset"):
    print("%s\t%s" % (key, obj.get(key, "")))' 2>/dev/null
		return $?
	fi

	if cmd_exists node; then
		# shellcheck disable=SC2016
		node -e 'let data="";process.stdin.on("data",c=>data+=c);process.stdin.on("end",()=>{const obj=JSON.parse(data||"{}");for(const key of ["version","source_repo","channel","bootstrap_min","windows_asset","unix_asset","checksum_asset"]){process.stdout.write(`${key}\t${obj[key]||""}\n`);}});' 2>/dev/null
		return $?
	fi

	return 1
}

self_update_verify_digest() {
	local label="$1"
	local expected="$2"
	local path="$3"

	case "$expected" in
	sha256:*)
		expected="${expected#sha256:}"
		;;
	*)
		warn "updates: self-update ${label} digest missing or unsupported; continuing"
		return 1
		;;
	esac

	local actual=""
	if ! actual="$(self_update_sha256_file "$path")"; then
		warn "updates: self-update sha256 tool missing; continuing"
		return 1
	fi
	if [ "$actual" != "$expected" ]; then
		warn "updates: self-update ${label} digest mismatch; continuing"
		return 1
	fi
	return 0
}

self_update_expected_sum_for_asset() {
	local sums_path="$1"
	local asset_name="$2"

	awk -v asset="$asset_name" '$2 ~ ("(^|/)" asset "$"){print $1; exit}' "$sums_path" 2>/dev/null || true
}

self_update_release_manifest_valid() {
	local manifest_path="$1"
	local expected_version="$2"

	local version=""
	local source_repo=""
	local channel=""
	local bootstrap_min=""
	local windows_asset=""
	local unix_asset=""
	local checksum_asset=""
	local key value

	while IFS=$'\t' read -r key value; do
		case "$key" in
		version) version="$value" ;;
		source_repo) source_repo="$value" ;;
		channel) channel="$value" ;;
		bootstrap_min) bootstrap_min="$value" ;;
		windows_asset) windows_asset="$value" ;;
		unix_asset) unix_asset="$value" ;;
		checksum_asset) checksum_asset="$value" ;;
		esac
	done <<<"$(self_update_parse_release_manifest <"$manifest_path" 2>/dev/null || true)"

	[ "$version" = "$expected_version" ] || return 1
	[ "$source_repo" = "$SELF_UPDATE_REPO" ] || return 1
	[ "$channel" = "$SELF_UPDATE_RELEASE_CHANNEL" ] || return 1
	case "$bootstrap_min" in
	'' | *[!0-9]*)
		return 1
		;;
	esac
	[ "$windows_asset" = "$SELF_UPDATE_WINDOWS_ASSET_NAME" ] || return 1
	[ "$unix_asset" = "$SELF_UPDATE_UNIX_ASSET_NAME" ] || return 1
	[ "$checksum_asset" = "$SELF_UPDATE_CHECKSUM_ASSET_NAME" ] || return 1
	return 0
}

self_update_script_file_version() {
	local path="$1"

	awk -F'"' '/^UPDATES_VERSION=/{print $2; exit}' "$path" 2>/dev/null || true
}

self_update_verify_installed_copy() {
	local path="$1"
	local expected_version="$2"
	local actual_version=""

	actual_version="$(UPDATES_SELF_UPDATE=0 UPDATES_SELF_UPDATED=1 "$path" --version 2>/dev/null | tr -d '\r')" || return 1
	[ "$actual_version" = "$expected_version" ]
}

self_update_cache_latest_is_newer_than_current() {
	local latest_tag="$1"
	local latest="${latest_tag#v}"
	semver_is_valid "$latest" || return 1
	semver_lt "$UPDATES_VERSION" "$latest"
}

self_update_reject_removed_repo_override() {
	if [ -n "${UPDATES_SELF_UPDATE_REPO+x}" ] && [ -n "${UPDATES_SELF_UPDATE_REPO}" ]; then
		die "UPDATES_SELF_UPDATE_REPO is no longer supported in v2.0.0; self-update is fixed to ${SELF_UPDATE_REPO}"
	fi
}

self_update_sha256_file() {
	local path="$1"
	if cmd_exists sha256sum; then
		sha256sum "$path" | awk '{print $1}'
		return 0
	fi
	if cmd_exists shasum; then
		shasum -a 256 "$path" | awk '{print $1}'
		return 0
	fi
	return 1
}

self_update_current_epoch() {
	date +%s
}

self_update_cache_root() {
	if [ -n "${XDG_CACHE_HOME:-}" ]; then
		stdout_print "${XDG_CACHE_HOME}/updates"
		return 0
	fi
	local home_dir=""
	if ! home_dir="$(updates_home_dir)"; then
		return 1
	fi
	if is_macos; then
		stdout_print "${home_dir}/Library/Caches/updates"
		return 0
	fi
	stdout_print "${home_dir}/.cache/updates"
}

self_update_cache_repo_key() {
	local repo="$1"
	local key="${repo//\//_}"
	key="${key//[^[:alnum:]._-]/_}"
	stdout_print "$key"
}

self_update_cache_file() {
	local repo="$1"
	local root=""
	local key=""

	if ! root="$(self_update_cache_root)"; then
		return 1
	fi
	if ! key="$(self_update_cache_repo_key "$repo")"; then
		return 1
	fi

	stdout_print "${root}/self-update-${key}.cache"
}

self_update_cache_reset() {
	SELF_UPDATE_CACHE_CHECKED_AT=""
	SELF_UPDATE_CACHE_LATEST_TAG=""
}

self_update_cache_load() {
	local path="$1"
	self_update_cache_reset

	if [ ! -r "$path" ]; then
		return 1
	fi

	local key value
	while IFS='=' read -r key value; do
		case "$key" in
		checked_at) SELF_UPDATE_CACHE_CHECKED_AT="$value" ;;
		latest_tag) SELF_UPDATE_CACHE_LATEST_TAG="$value" ;;
		esac
	done <"$path"

	case "$SELF_UPDATE_CACHE_CHECKED_AT" in
	'' | *[!0-9]*)
		return 2
		;;
	esac

	local latest="${SELF_UPDATE_CACHE_LATEST_TAG#v}"
	if ! semver_is_valid "$latest"; then
		return 2
	fi

	return 0
}

self_update_cache_is_fresh() {
	local current_epoch="$1"
	local checked_at="$2"

	case "$current_epoch" in
	'' | *[!0-9]*)
		return 1
		;;
	esac
	case "$checked_at" in
	'' | *[!0-9]*)
		return 1
		;;
	esac

	if [ "$checked_at" -gt "$current_epoch" ]; then
		return 1
	fi

	[ $((current_epoch - checked_at)) -lt "$SELF_UPDATE_CACHE_TTL" ]
}

self_update_cache_write() {
	local path="$1"
	local checked_at="$2"
	local latest_tag="$3"
	local dir=""
	local tmp=""

	dir="$(dirname "$path")"
	if ! mkdir -p "$dir"; then
		debug "self-update: failed to create cache dir: $dir"
		return 1
	fi

	tmp="${path}.tmp.$$"
	if ! (
		umask 077
		printf 'checked_at=%s\n' "$checked_at" >"$tmp"
		printf 'latest_tag=%s\n' "$latest_tag" >>"$tmp"
	); then
		debug "self-update: failed to write cache temp file: $tmp"
		rm -f "$tmp"
		return 1
	fi

	if ! mv "$tmp" "$path"; then
		debug "self-update: failed to move cache file into place: $path"
		rm -f "$tmp"
		return 1
	fi

	return 0
}

maybe_self_update() {
	if ! self_update_enabled; then
		return 0
	fi
	if ! cmd_exists curl; then
		debug "self-update: curl not found; skipping"
		return 0
	fi
	if ! cmd_exists install; then
		debug "self-update: install not found; skipping"
		return 0
	fi

	local self_path=""
	if ! self_path="$(self_update_resolve_self_path)"; then
		debug "self-update: failed to resolve script path; skipping"
		return 0
	fi

	# Avoid mutating a git checkout; self-update is for installed binaries.
	if self_update_is_git_checkout "$self_path"; then
		debug "self-update: running from git checkout ($self_path); skipping"
		return 0
	fi

	if [ -L "$self_path" ]; then
		debug "self-update: installed as symlink; skipping (${self_path})"
		return 0
	fi

	local repo="${SELF_UPDATE_REPO}"
	local tag=""
	local release_json=""
	local cache_file=""
	if ! cache_file="$(self_update_cache_file "$repo")"; then
		debug "self-update: failed to resolve cache file; proceeding without cache"
		cache_file=""
	fi
	local current_epoch=""
	current_epoch="$(self_update_current_epoch 2>/dev/null || true)"
	local cache_state=1
	local live_check_needed=1

	if [ -n "$cache_file" ]; then
		self_update_cache_load "$cache_file"
		cache_state=$?

		if [ "$cache_state" -eq 0 ]; then
			if [ "$SELF_UPDATE_FORCE_REFRESH" -eq 1 ]; then
				debug "self-update: forcing live release check via --self-update"
			elif self_update_cache_is_fresh "$current_epoch" "$SELF_UPDATE_CACHE_CHECKED_AT"; then
				tag="$SELF_UPDATE_CACHE_LATEST_TAG"
				if self_update_cache_latest_is_newer_than_current "$tag"; then
					debug "self-update: cached release tag (${tag}) is newer; deferring live metadata check until cache expires"
				else
					debug "self-update: using cached release tag (${tag}) from ${cache_file}"
				fi
				return 0
			else
				debug "self-update: cached release tag is stale; refreshing (${cache_file})"
			fi
		elif [ "$cache_state" -eq 2 ]; then
			debug "self-update: ignoring invalid cache file: ${cache_file}"
		else
			debug "self-update: cache miss: ${cache_file}"
		fi
	fi

	if [ "$live_check_needed" -eq 1 ]; then
		if ! release_json="$(self_update_latest_release_json_github "$repo")"; then
			debug "self-update: failed to fetch latest release tag; skipping"
			return 0
		fi
	fi

	local release_draft="0"
	local release_prerelease="0"
	local release_immutable="0"
	local updates_url=""
	local updates_digest=""
	local manifest_url=""
	local manifest_digest=""
	local sums_url=""
	local sums_digest=""
	local parsed_release=""

	if [ -n "$release_json" ]; then
		if ! parsed_release="$(printf '%s' "$release_json" | self_update_parse_release_metadata 2>/dev/null)"; then
			warn "updates: self-update failed to parse release metadata; continuing"
			return 0
		fi

		local kind asset_name asset_digest asset_url value
		while IFS=$'\t' read -r kind asset_name asset_digest asset_url; do
			case "$kind" in
			tag_name)
				tag="$asset_name"
				;;
			draft)
				release_draft="$asset_name"
				;;
			prerelease)
				release_prerelease="$asset_name"
				;;
			immutable)
				release_immutable="$asset_name"
				;;
			asset)
				case "$asset_name" in
				"$SELF_UPDATE_UNIX_ASSET_NAME")
					updates_digest="$asset_digest"
					updates_url="$asset_url"
					;;
				"$SELF_UPDATE_RELEASE_MANIFEST_NAME")
					manifest_digest="$asset_digest"
					manifest_url="$asset_url"
					;;
				"$SELF_UPDATE_CHECKSUM_ASSET_NAME")
					sums_digest="$asset_digest"
					sums_url="$asset_url"
					;;
				esac
				;;
			esac
		done <<<"$parsed_release"

		if [ -n "$cache_file" ] && [ -n "$current_epoch" ] && [ -n "$tag" ]; then
			self_update_cache_write "$cache_file" "$current_epoch" "$tag" || true
		fi
	fi

	local latest="${tag#v}"
	if ! semver_is_valid "$latest"; then
		debug "self-update: latest tag is not SemVer: $tag"
		return 0
	fi

	if ! semver_lt "$UPDATES_VERSION" "$latest"; then
		return 0
	fi

	if [ "$release_draft" != "0" ] || [ "$release_prerelease" != "0" ] || [ "$release_immutable" != "1" ]; then
		warn "updates: self-update release metadata did not satisfy trust requirements; continuing"
		return 0
	fi
	if [ -z "$updates_url" ] || [ -z "$manifest_url" ] || [ -z "$sums_url" ]; then
		warn "updates: self-update release assets are incomplete; continuing"
		return 0
	fi
	if [ -z "$updates_digest" ] || [ -z "$manifest_digest" ] || [ -z "$sums_digest" ]; then
		warn "updates: self-update release asset digests are incomplete; continuing"
		return 0
	fi

	warn "updates: self-update available (${UPDATES_VERSION} -> ${latest})"

	local tmp_dir=""
	tmp_dir="$(mktemp -d 2>/dev/null || mktemp -d -t updates-self-update)" || {
		debug "self-update: mktemp failed; skipping"
		return 0
	}

	local tmp_updates="${tmp_dir}/updates"
	local tmp_manifest="${tmp_dir}/${SELF_UPDATE_RELEASE_MANIFEST_NAME}"
	local tmp_sums="${tmp_dir}/SHA256SUMS"

	if ! curl -fsSL --connect-timeout 2 --max-time 20 -o "$tmp_updates" "$updates_url" 2>/dev/null; then
		warn "updates: self-update download failed; continuing"
		rm -rf "$tmp_dir"
		return 0
	fi
	if ! curl -fsSL --connect-timeout 2 --max-time 20 -o "$tmp_manifest" "$manifest_url" 2>/dev/null; then
		warn "updates: self-update manifest download failed; continuing"
		rm -rf "$tmp_dir"
		return 0
	fi
	if ! curl -fsSL --connect-timeout 2 --max-time 20 -o "$tmp_sums" "$sums_url" 2>/dev/null; then
		warn "updates: self-update checksum download failed; continuing"
		rm -rf "$tmp_dir"
		return 0
	fi

	if ! self_update_verify_digest "script" "$updates_digest" "$tmp_updates"; then
		rm -rf "$tmp_dir"
		return 0
	fi
	if ! self_update_verify_digest "manifest" "$manifest_digest" "$tmp_manifest"; then
		rm -rf "$tmp_dir"
		return 0
	fi
	if ! self_update_verify_digest "checksum" "$sums_digest" "$tmp_sums"; then
		rm -rf "$tmp_dir"
		return 0
	fi

	local expected=""
	expected="$(self_update_expected_sum_for_asset "$tmp_sums" "$SELF_UPDATE_UNIX_ASSET_NAME")"
	if [ -z "$expected" ]; then
		warn "updates: self-update checksum missing; continuing"
		rm -rf "$tmp_dir"
		return 0
	fi

	local actual=""
	if ! actual="$(self_update_sha256_file "$tmp_updates")"; then
		warn "updates: self-update sha256 tool missing; continuing"
		rm -rf "$tmp_dir"
		return 0
	fi
	if [ "$actual" != "$expected" ]; then
		warn "updates: self-update checksum mismatch; continuing"
		rm -rf "$tmp_dir"
		return 0
	fi

	if ! self_update_release_manifest_valid "$tmp_manifest" "$latest"; then
		warn "updates: self-update manifest is invalid; continuing"
		rm -rf "$tmp_dir"
		return 0
	fi

	local script_version=""
	script_version="$(self_update_script_file_version "$tmp_updates")"
	if [ "$script_version" != "$latest" ]; then
		warn "updates: self-update downloaded script looks invalid; continuing"
		rm -rf "$tmp_dir"
		return 0
	fi

	local self_dir=""
	self_dir="$(cd "$(dirname "$self_path")" && pwd)"
	local staged_self="${self_path}.new.$$"
	if [ -w "$self_dir" ]; then
		if ! install -m 0755 "$tmp_updates" "$staged_self"; then
			warn "updates: self-update install failed; continuing"
			rm -rf "$tmp_dir"
			return 0
		fi
		if ! self_update_verify_installed_copy "$staged_self" "$latest"; then
			warn "updates: self-update staged copy failed verification; continuing"
			rm -f "$staged_self"
			rm -rf "$tmp_dir"
			return 0
		fi
		if ! mv "$staged_self" "$self_path"; then
			warn "updates: self-update install failed; continuing"
			rm -f "$staged_self"
			rm -rf "$tmp_dir"
			return 0
		fi
	elif [ -w "$self_path" ]; then
		if ! install -m 0755 "$tmp_updates" "$self_path"; then
			warn "updates: self-update install failed; continuing"
			rm -rf "$tmp_dir"
			return 0
		fi
		if ! self_update_verify_installed_copy "$self_path" "$latest"; then
			warn "updates: self-update installed copy failed verification; continuing"
			rm -rf "$tmp_dir"
			return 0
		fi
	else
		if ! cmd_exists sudo; then
			warn "updates: self-update requires write access to $self_path (try installing to ~/.local/bin)"
			rm -rf "$tmp_dir"
			return 0
		fi

		local -a sudo_prefix=(sudo)
		if [ "$NON_INTERACTIVE" -eq 1 ]; then
			sudo_prefix=(sudo -n)
		fi
		if ! "${sudo_prefix[@]}" install -m 0755 "$tmp_updates" "$self_path"; then
			warn "updates: self-update requires sudo or a user-writable install location (e.g. ~/.local/bin)"
			rm -rf "$tmp_dir"
			return 0
		fi
		if ! self_update_verify_installed_copy "$self_path" "$latest"; then
			warn "updates: self-update installed copy failed verification; continuing"
			rm -rf "$tmp_dir"
			return 0
		fi
	fi

	rm -rf "$tmp_dir"

	warn "updates: updated to ${latest}; restarting"
	export UPDATES_SELF_UPDATED=1
	exec "$self_path" "${ORIGINAL_ARGS[@]}"
}

###############################################################################
# SECTION: cli — usage, config parsing, argument parsing
###############################################################################

contains_word() {
	local needle="$1"
	shift
	local item
	for item in "$@"; do
		if [ "$item" = "$needle" ]; then
			return 0
		fi
	done
	return 1
}

normalize_module_list() {
	# Converts a CSV list like "brew, mas,python" to space-separated words.
	local s="$1"
	s="${s//,/ }"
	stdout_print "$s"
}

is_module_known() {
	module_known "$1"
}

module_description() {
	if ! module_lookup "$1"; then
		print ""
		return 1
	fi

	print "$MODULE_LOOKUP_DESCRIPTION"
}

list_modules() {
	local name handler platform opt_in description
	while IFS='|' read -r -u3 name handler platform opt_in description; do
		[ -n "$name" ] || continue
		printf '%-8s %s\n' "$name" "$description"
	done 3<<<"$MODULE_REGISTRY"
}

usage() {
	cat <<EOF
${SCRIPT_NAME} v${UPDATES_VERSION}

Updates common tooling on macOS and Linux (Homebrew, npm globals, pip globals, etc.).

Usage:
  ${SCRIPT_NAME} [options]

Options:
  -h, --help               Show this help
      --version            Print version
      --list-modules       List available modules
      --dry-run            Print what would run; make no changes
      --only <list>        Run only these modules (CSV; or quote a space-separated list)
      --skip <list>        Skip these modules (CSV; or quote a space-separated list)
      --strict             Stop on first failure
      --log-level <level>  Output level: error, warn, info, debug (default: info)
      --json               Emit JSONL events to stdout (human output to stderr)
      --[no-]self-update   Check GitHub for a newer version and update this script (default: enabled)
  -n, --non-interactive    Avoid interactive prompts when possible
      --no-config          Ignore ~/.updatesrc
      --no-emoji           Disable emoji in output
      --no-color           Disable ANSI colors in output
      --log-file <path>    Append human output to a log file
      --parallel <N>       Parallelism for pip upgrades (default: ${PARALLEL})
      --pip-force          Pass --break-system-packages to pip (dangerous)
      --brew-mode <mode>   Homebrew scope: formula, casks, greedy
      --[no-]brew-cleanup  Run brew cleanup after upgrade (default: enabled)
      --full               Enable everything (brew greedy + mas + macos + all detected modules)
      --[no-]mas-upgrade   Upgrade Mac App Store apps (default: disabled)
      --[no-]macos-updates List available macOS software updates (default: disabled)

Examples:
  ${SCRIPT_NAME}
  ${SCRIPT_NAME} --dry-run
  ${SCRIPT_NAME} --only brew,node --brew-mode formula
  ${SCRIPT_NAME} --json -n --no-self-update --log-level warn
  ${SCRIPT_NAME} --skip python --log-file ./updates.log

EOF
}

pre_scan_no_config() {
	local arg
	for arg in "$@"; do
		case "$arg" in
		--no-config)
			NO_CONFIG=1
			;;
		--json)
			JSON=1
			;;
		-h | --help | --version | --list-modules)
			# These commands don't need config defaults; avoid config parse warnings
			# polluting help/version output (and keep --json + --help sane).
			NO_CONFIG=1
			;;
		esac
	done
	return 0
}

config_parse_module_list() {
	local list="$1"
	local m
	for m in $(normalize_module_list "$list"); do
		[ -n "$m" ] || continue
		if ! is_module_known "$m"; then
			warn "config: unknown module in SKIP_MODULES: $m"
			continue
		fi
		config_skip_modules+=("$m")
	done
}

config_set_bool() {
	local config_key="$1" val="$2" varname="$3"
	case "$val" in
	0) eval "$varname=0" ;;
	1) eval "$varname=1" ;;
	*) warn "config: $config_key must be 0 or 1 (got: $val)" ;;
	esac
}

read_config() {
	if [ "$NO_CONFIG" -eq 1 ]; then
		return 0
	fi

	local config_path=""
	if ! config_path="$(updates_config_path)"; then
		return 0
	fi
	if [ ! -f "$config_path" ]; then
		return 0
	fi

	local line key val
	local first_line=1
	while IFS= read -r line || [ -n "$line" ]; do
		if [ "$first_line" -eq 1 ]; then
			line="${line#$'\xef\xbb\xbf'}"
			first_line=0
		fi

		# Trim whitespace.
		line="${line#"${line%%[![:space:]]*}"}"
		line="${line%"${line##*[![:space:]]}"}"

		# Skip empty lines and comments.
		[ -n "$line" ] || continue
		case "$line" in
		\#*) continue ;;
		esac

		if ! [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
			continue
		fi

		key="${BASH_REMATCH[1]}"
		val="${BASH_REMATCH[2]}"

		# Trim whitespace around the value.
		val="${val#"${val%%[![:space:]]*}"}"
		val="${val%"${val##*[![:space:]]}"}"

		# Strip a single layer of surrounding quotes.
		case "$val" in
		\"*\")
			val="${val#\"}"
			val="${val%\"}"
			;;
		\'*\')
			val="${val#\'}"
			val="${val%\'}"
			;;
		esac

		case "$key" in
		SKIP_MODULES)
			config_skip_modules=()
			config_parse_module_list "$val"
			;;
		BREW_MODE)
			set_brew_mode "$val" config || true
			;;
		BREW_CLEANUP)
			config_set_bool BREW_CLEANUP "$val" BREW_CLEANUP
			;;
		MAS_UPGRADE)
			config_set_bool MAS_UPGRADE "$val" MAS_UPGRADE
			;;
		MACOS_UPDATES)
			config_set_bool MACOS_UPDATES "$val" MACOS_UPDATES
			;;
		LOG_LEVEL)
			case "$val" in
			error | warn | info | debug) set_log_level "$val" ;;
			*) warn "config: LOG_LEVEL must be error, warn, info, or debug (got: $val)" ;;
			esac
			;;
		PARALLEL)
			case "$val" in
			'' | *[!0-9]*)
				warn "config: PARALLEL must be a positive integer (got: $val)"
				;;
			*)
				if [ "$val" -lt 1 ]; then
					warn "config: PARALLEL must be >= 1 (got: $val)"
				else
					PARALLEL="$val"
				fi
				;;
			esac
			;;
		PIP_FORCE)
			config_set_bool PIP_FORCE "$val" PYTHON_BREAK_SYSTEM_PACKAGES
			;;
		SELF_UPDATE)
			config_set_bool SELF_UPDATE "$val" SELF_UPDATE
			;;
		NO_EMOJI)
			config_set_bool NO_EMOJI "$val" NO_EMOJI
			;;
		NO_COLOR)
			config_set_bool NO_COLOR "$val" NO_COLOR_OUTPUT
			;;
		GO_BINARIES)
			GO_BINARIES="$val"
			;;
		REPOS_DIR)
			REPOS_DIR="$val"
			;;
		*)
			# Unknown keys are ignored for forward compatibility.
			:
			;;
		esac
	done <"$config_path"
}

parse_args() {
	while [ $# -gt 0 ]; do
		case "$1" in
		-h | --help)
			usage
			exit 0
			;;
		--version)
			print "${UPDATES_VERSION}"
			exit 0
			;;
		--list-modules)
			list_modules
			exit 0
			;;
		--dry-run)
			DRY_RUN=1
			;;
		--strict)
			STRICT=1
			;;
		--log-level)
			shift
			[ $# -gt 0 ] || die "--log-level requires a value"
			set_log_level "$1"
			;;
		--json)
			JSON=1
			;;
		--self-update)
			SELF_UPDATE=1
			SELF_UPDATE_FORCE_REFRESH=1
			;;
		--no-self-update)
			SELF_UPDATE=0
			;;
		--no-emoji)
			NO_EMOJI=1
			;;
		--no-color)
			NO_COLOR_OUTPUT=1
			;;
		--no-config)
			NO_CONFIG=1
			;;
		-n | --non-interactive)
			NON_INTERACTIVE=1
			;;
		--pip-force)
			PYTHON_BREAK_SYSTEM_PACKAGES=1
			;;
		--full)
			set_brew_mode greedy
			MAS_UPGRADE=1
			MACOS_UPDATES=1
			;;
		--log-file)
			shift
			[ $# -gt 0 ] || die "--log-file requires a path"
			LOG_FILE="$1"
			;;
		--parallel)
			shift
			[ $# -gt 0 ] || die "--parallel requires a number"
			PARALLEL="$1"
			case "$PARALLEL" in
			'' | *[!0-9]*)
				die "--parallel must be a positive integer"
				;;
			esac
			if [ "$PARALLEL" -lt 1 ]; then
				die "--parallel must be >= 1"
			fi
			;;
		--only)
			shift
			[ $# -gt 0 ] || die "--only requires a module list"
			local list
			list="$(normalize_module_list "$1")"
			local m
			for m in $list; do
				is_module_known "$m" || die "Unknown module in --only: $m"
				only_modules+=("$m")
			done
			;;
		--skip)
			shift
			[ $# -gt 0 ] || die "--skip requires a module list"
			local list
			list="$(normalize_module_list "$1")"
			local m
			for m in $list; do
				is_module_known "$m" || die "Unknown module in --skip: $m"
				skip_modules+=("$m")
			done
			;;
		--brew-mode)
			shift
			[ $# -gt 0 ] || die "--brew-mode requires a value"
			set_brew_mode "$1"
			;;
		--brew-cleanup)
			BREW_CLEANUP=1
			;;
		--no-brew-cleanup)
			BREW_CLEANUP=0
			;;
		--mas-upgrade)
			MAS_UPGRADE=1
			;;
		--no-mas-upgrade)
			MAS_UPGRADE=0
			;;
		--macos-updates)
			MACOS_UPDATES=1
			;;
		--no-macos-updates)
			MACOS_UPDATES=0
			;;
		--)
			shift
			break
			;;
		-*)
			die "Unknown option: $1"
			;;
		*)
			die "Unexpected argument: $1"
			;;
		esac
		shift
	done
}

###############################################################################
# SECTION: selection — module filtering, dependency checks, helpers
###############################################################################

module_selected() {
	local name="$1"

	if contains_word "$name" "${skip_modules[@]}"; then
		return 1
	fi

	if [ "${#only_modules[@]}" -gt 0 ]; then
		contains_word "$name" "${only_modules[@]}"
		return $?
	fi

	if contains_word "$name" "${config_skip_modules[@]}"; then
		return 1
	fi

	if ! module_enabled_by_default "$name"; then
		return 1
	fi

	module_supported "$name"
}

missing_dependency_is_error() {
	# In --only mode, missing deps should be treated as an error.
	if [ "${#only_modules[@]}" -gt 0 ]; then
		return 0
	fi
	return 1
}

ensure_cmd_or_skip() {
	local cmd="$1"
	local module="$2"
	if cmd_exists "$cmd"; then
		return 0
	fi

	if missing_dependency_is_error; then
		err "$module: required command not found: $cmd"
		return 1
	fi

	log "Skipping $module: $cmd not found."
	return 2
}

json_pairs() {
	# Prints tab-delimited key/value pairs from a JSON object on stdin.
	if python_launcher_resolve; then
		python_run_cmd -c 'import sys, json; obj=json.load(sys.stdin); [print("%s\t%s" % (k, v)) for k, v in obj.items()]'
		return $?
	fi
	if cmd_exists node; then
		node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{const o=JSON.parse(d||"{}");for(const k of Object.keys(o)){process.stdout.write(k+"\t"+o[k]+"\n");}});'
		return $?
	fi
	return 1
}

###############################################################################
# SECTION: modules — brew, shell, linux, node, python, uv, mas, pipx,
#                     rustup, claude, mise, go, macos
###############################################################################

python_externally_managed() {
	if ! python_launcher_resolve; then
		return 1
	fi

	local out
	if ! out="$(
		python_run_cmd -c 'import sysconfig, pathlib; paths=sysconfig.get_paths(); c=[pathlib.Path(paths[k])/"EXTERNALLY-MANAGED" for k in ("stdlib","platstdlib","purelib","platlib") if paths.get(k)]; print("1" if any(p.exists() for p in c) else "0")' 2>/dev/null
	)"; then
		return 1
	fi
	[ "$out" = "1" ]
}

module_brew() {
	log "Homebrew $(emoji "🍺")"
	ensure_cmd_or_skip brew brew || return $?

	if is_macos && [ "$BREW_CASKS" -eq 0 ] && [ "$BREW_CASKS_EXPLICIT" -eq 0 ] && [ "$BREW_FORMULA_DEFAULT_HINT_EMITTED" -eq 0 ]; then
		log "Defaulting to brew formula upgrades only on macOS. Enable casks with --brew-mode casks (or --full)."
		BREW_FORMULA_DEFAULT_HINT_EMITTED=1
	fi

	if is_macos && [ "$BREW_CASKS" -eq 1 ]; then
		warn "Homebrew cask upgrades may modify /Applications."
		warn "On macOS 26+, cask upgrades may be blocked unless your terminal app is allowed under Privacy & Security → App Management."
		warn "If you see a system notification like \"<Terminal App> tried modifying your system but was stopped/prevented\", enable App Management for your terminal app (e.g. Ghostty), or rerun with --brew-mode formula."
	fi

	if [ "$DRY_RUN" -eq 1 ]; then
		log "DRY RUN: brew update"
		if [ "$BREW_CASKS" -eq 0 ]; then
			log "DRY RUN: brew upgrade --formula"
		elif [ "$BREW_GREEDY" -eq 1 ]; then
			log "DRY RUN: brew upgrade --greedy"
		else
			log "DRY RUN: brew upgrade"
		fi
		if [ "$BREW_CLEANUP" -eq 1 ]; then
			log "DRY RUN: brew cleanup"
		fi
		return 0
	fi

	run brew update || return 1

	if [ "$BREW_CASKS" -eq 0 ]; then
		run brew upgrade --formula || return 1
	elif [ "$BREW_GREEDY" -eq 1 ]; then
		run brew upgrade --greedy || return 1
	else
		run brew upgrade || return 1
	fi

	if [ "$BREW_CLEANUP" -eq 1 ]; then
		run brew cleanup || return 1
	fi

	return 0
}

shell_git_is_repo() {
	local dir="$1"
	[ -e "${dir}/.git" ]
}

shell_detect_omz_dir() {
	if [ -n "${ZSH:-}" ] && [ -d "${ZSH}" ]; then
		stdout_print "$ZSH"
		return 0
	fi
	local home_dir=""
	if ! home_dir="$(updates_home_dir)"; then
		return 1
	fi
	if [ -d "${home_dir}/.oh-my-zsh" ]; then
		stdout_print "${home_dir}/.oh-my-zsh"
		return 0
	fi
	return 1
}

shell_detect_omz_custom_dir() {
	local zsh_dir="$1"
	if [ -n "${ZSH_CUSTOM:-}" ] && [ -d "${ZSH_CUSTOM}" ]; then
		stdout_print "$ZSH_CUSTOM"
		return 0
	fi
	if [ -d "${zsh_dir}/custom" ]; then
		stdout_print "${zsh_dir}/custom"
		return 0
	fi
	return 1
}

module_shell() {
	log "Shell customization $(emoji "🐚")"
	ensure_cmd_or_skip git shell || return $?

	local omz_dir=""
	if ! omz_dir="$(shell_detect_omz_dir)"; then
		log "Skipping shell: Oh My Zsh not found."
		return 2
	fi

	local custom_dir=""
	custom_dir="$(shell_detect_omz_custom_dir "$omz_dir" || true)"

	local git_terminal_prompt_prev=""
	local git_terminal_prompt_was_set=0
	if [ "$NON_INTERACTIVE" -eq 1 ]; then
		if [ -n "${GIT_TERMINAL_PROMPT+x}" ]; then
			git_terminal_prompt_was_set=1
			git_terminal_prompt_prev="${GIT_TERMINAL_PROMPT}"
		fi
		export GIT_TERMINAL_PROMPT=0
	fi

	local -a repos=()
	if shell_git_is_repo "$omz_dir"; then
		repos+=("$omz_dir")
	else
		warn "shell: Oh My Zsh is not a git repo: ${omz_dir}"
	fi

	if [ -n "$custom_dir" ]; then
		local root
		for root in "${custom_dir}/plugins" "${custom_dir}/themes"; do
			if [ ! -d "$root" ]; then
				continue
			fi

			local dir
			for dir in "${root}"/*; do
				[ -e "$dir" ] || continue
				[ -d "$dir" ] || continue
				if shell_git_is_repo "$dir"; then
					repos+=("$dir")
				fi
			done
		done
	fi

	if [ "${#repos[@]}" -eq 0 ]; then
		log "Skipping shell: no git repos detected."
		if [ "$NON_INTERACTIVE" -eq 1 ]; then
			if [ "$git_terminal_prompt_was_set" -eq 1 ]; then
				export GIT_TERMINAL_PROMPT="$git_terminal_prompt_prev"
			else
				unset GIT_TERMINAL_PROMPT
			fi
		fi
		return 2
	fi

	local failed=0
	local repo
	for repo in "${repos[@]}"; do
		if [ "$DRY_RUN" -eq 1 ]; then
			log "DRY RUN: git -C ${repo} pull --ff-only"
			continue
		fi

		log "Updating: ${repo}"
		if ! run git -C "$repo" pull --ff-only; then
			failed=1
		fi
	done

	if [ "$NON_INTERACTIVE" -eq 1 ]; then
		if [ "$git_terminal_prompt_was_set" -eq 1 ]; then
			export GIT_TERMINAL_PROMPT="$git_terminal_prompt_prev"
		else
			unset GIT_TERMINAL_PROMPT
		fi
	fi

	if [ "$failed" -eq 1 ]; then
		return 1
	fi
	return 0
}

module_repos() {
	log "Development repos $(emoji "📦")"
	ensure_cmd_or_skip git repos || return $?

	local home_dir=""
	if ! home_dir="$(updates_home_dir)"; then
		log "Skipping repos: home directory not available."
		return 2
	fi

	local base_dir="${REPOS_DIR:-${home_dir}/GitRepos}"
	if [ ! -d "$base_dir" ]; then
		log "Skipping repos: base directory not found: ${base_dir}"
		return 2
	fi

	local git_terminal_prompt_prev=""
	local git_terminal_prompt_was_set=0
	if [ "$NON_INTERACTIVE" -eq 1 ]; then
		if [ -n "${GIT_TERMINAL_PROMPT+x}" ]; then
			git_terminal_prompt_was_set=1
			git_terminal_prompt_prev="${GIT_TERMINAL_PROMPT}"
		fi
		export GIT_TERMINAL_PROMPT=0
	fi

	local -a repos=()
	local dir
	for dir in "${base_dir}"/aman-*-setup; do
		[ -e "$dir" ] || continue
		[ -d "$dir" ] || continue
		if shell_git_is_repo "$dir"; then
			repos+=("$dir")
		fi
	done

	if [ "${#repos[@]}" -eq 0 ]; then
		log "Skipping repos: no aman-*-setup repos found in ${base_dir}."
		if [ "$NON_INTERACTIVE" -eq 1 ]; then
			if [ "$git_terminal_prompt_was_set" -eq 1 ]; then
				export GIT_TERMINAL_PROMPT="$git_terminal_prompt_prev"
			else
				unset GIT_TERMINAL_PROMPT
			fi
		fi
		return 2
	fi

	local failed=0
	local repo
	for repo in "${repos[@]}"; do
		if [ "$DRY_RUN" -eq 1 ]; then
			log "DRY RUN: git -C ${repo} pull --ff-only"
			if [ -x "${repo}/scripts/update.sh" ]; then
				log "DRY RUN: (cd ${repo} && ./scripts/update.sh)"
			fi
			continue
		fi

		log "Updating: ${repo}"
		if run git -C "$repo" pull --ff-only; then
			if [ -x "${repo}/scripts/update.sh" ]; then
				log "Running post-pull: ./scripts/update.sh"
				if ! (cd "$repo" && run ./scripts/update.sh); then
					warn "repos: post-pull script failed: ${repo}/scripts/update.sh"
				fi
			fi
		else
			failed=1
		fi
	done

	if [ "$NON_INTERACTIVE" -eq 1 ]; then
		if [ "$git_terminal_prompt_was_set" -eq 1 ]; then
			export GIT_TERMINAL_PROMPT="$git_terminal_prompt_prev"
		else
			unset GIT_TERMINAL_PROMPT
		fi
	fi

	if [ "$failed" -eq 1 ]; then
		return 1
	fi
	return 0
}

module_linux() {
	if ! is_linux; then
		return 2
	fi

	log "Linux system packages $(emoji "🐧")"

	local pm=""
	if cmd_exists apt-get; then
		pm="apt-get"
	elif cmd_exists dnf; then
		pm="dnf"
	elif cmd_exists yum; then
		pm="yum"
	elif cmd_exists pacman; then
		pm="pacman"
	elif cmd_exists zypper; then
		pm="zypper"
	elif cmd_exists apk; then
		pm="apk"
	else
		if missing_dependency_is_error; then
			err "linux: no supported package manager found (apt-get/dnf/yum/pacman/zypper/apk)"
			return 1
		fi
		log "Skipping linux: no supported package manager found."
		return 2
	fi

	local -a sudo_prefix=()
	if [ "$(id -u)" -ne 0 ]; then
		if ! cmd_exists sudo; then
			err "linux: requires root or sudo"
			return 1
		fi
		sudo_prefix=(sudo)
		if [ "$NON_INTERACTIVE" -eq 1 ]; then
			sudo_prefix=(sudo -n)
		fi
	fi

	case "$pm" in
	apt-get)
		local -a env_prefix=()
		if [ "$NON_INTERACTIVE" -eq 1 ]; then
			env_prefix=(env DEBIAN_FRONTEND=noninteractive)
		fi

		local -a update_cmd=("${sudo_prefix[@]}" "${env_prefix[@]}" apt-get update)
		local -a upgrade_cmd=("${sudo_prefix[@]}" "${env_prefix[@]}" apt-get upgrade)
		if [ "$NON_INTERACTIVE" -eq 1 ]; then
			upgrade_cmd+=(-y)
		fi

		if [ "$DRY_RUN" -eq 1 ]; then
			log "DRY RUN: ${update_cmd[*]}"
			log "DRY RUN: ${upgrade_cmd[*]}"
			return 0
		fi

		run "${update_cmd[@]}" || return 1
		run "${upgrade_cmd[@]}" || return 1
		return 0
		;;
	dnf)
		local -a upgrade_cmd=("${sudo_prefix[@]}" dnf upgrade)
		if [ "$NON_INTERACTIVE" -eq 1 ]; then
			upgrade_cmd+=(-y)
		fi

		if [ "$DRY_RUN" -eq 1 ]; then
			log "DRY RUN: ${upgrade_cmd[*]}"
			return 0
		fi

		run "${upgrade_cmd[@]}" || return 1
		return 0
		;;
	yum)
		local -a upgrade_cmd=("${sudo_prefix[@]}" yum update)
		if [ "$NON_INTERACTIVE" -eq 1 ]; then
			upgrade_cmd+=(-y)
		fi

		if [ "$DRY_RUN" -eq 1 ]; then
			log "DRY RUN: ${upgrade_cmd[*]}"
			return 0
		fi

		run "${upgrade_cmd[@]}" || return 1
		return 0
		;;
	pacman)
		local -a upgrade_cmd=("${sudo_prefix[@]}" pacman -Syu)
		if [ "$NON_INTERACTIVE" -eq 1 ]; then
			upgrade_cmd+=(--noconfirm)
		fi

		if [ "$DRY_RUN" -eq 1 ]; then
			log "DRY RUN: ${upgrade_cmd[*]}"
			return 0
		fi

		run "${upgrade_cmd[@]}" || return 1
		return 0
		;;
	zypper)
		local -a refresh_cmd=("${sudo_prefix[@]}" zypper refresh)
		local -a update_cmd=("${sudo_prefix[@]}" zypper update)
		if [ "$NON_INTERACTIVE" -eq 1 ]; then
			refresh_cmd+=(--non-interactive)
			update_cmd+=(--non-interactive)
		fi

		if [ "$DRY_RUN" -eq 1 ]; then
			log "DRY RUN: ${refresh_cmd[*]}"
			log "DRY RUN: ${update_cmd[*]}"
			return 0
		fi

		run "${refresh_cmd[@]}" || return 1
		run "${update_cmd[@]}" || return 1
		return 0
		;;
	apk)
		local -a update_cmd=("${sudo_prefix[@]}" apk update)
		local -a upgrade_cmd=("${sudo_prefix[@]}" apk upgrade)

		if [ "$DRY_RUN" -eq 1 ]; then
			log "DRY RUN: ${update_cmd[*]}"
			log "DRY RUN: ${upgrade_cmd[*]}"
			return 0
		fi

		run "${update_cmd[@]}" || return 1
		run "${upgrade_cmd[@]}" || return 1
		return 0
		;;
	*)
		err "linux: unsupported package manager: $pm"
		return 1
		;;
	esac
}

module_winget() {
	log "Skipping winget: native Windows support uses updates.ps1."
